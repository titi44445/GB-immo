function favBtnHTML(id,score,isFav){
  const R=18,C=2*Math.PI*R;
  const hasPct=score!==undefined;
  const pct=hasPct?score:0;
  const ringColor=pct>=75?'#5cad7b':pct>=45?'#c8a96e':'#e05c5c';
  const fillColor=isFav?'#e05c5c':(hasPct?ringColor:'#ccc');
  const fillPct=hasPct?pct:(isFav?100:0);
  const clipY=24-(24*fillPct/100);
  const dashOff=hasPct?C-(C*pct/100):C;
  const heart="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z";
  const ringHTML=hasPct?`<svg class="ring-svg" viewBox="0 0 48 48"><circle class="ring-track" cx="24" cy="24" r="${R}"/><circle class="ring-fill" cx="24" cy="24" r="${R}" stroke="${ringColor}" stroke-dasharray="${C}" stroke-dashoffset="${dashOff}" transform="rotate(-90 24 24)"/></svg>`:'';
  const pctHTML=hasPct?`<span class="pct-txt" style="color:${ringColor}">${pct}%</span>`:'';
  return `<button class="fav-ring-btn${isFav?' liked':''}" onclick="toggleFav(${id})" title="${isFav?'Retirer des favoris':'Ajouter aux favoris'}">${ringHTML}<svg class="heart-svg" viewBox="0 0 24 24"><defs><clipPath id="cf${id}"><rect x="0" y="${clipY}" width="24" height="${24-clipY}"/></clipPath><clipPath id="ce${id}"><rect x="0" y="0" width="24" height="${clipY}"/></clipPath></defs><path d="${heart}" fill="#ddd"/><path d="${heart}" fill="${fillColor}" clip-path="url(#cf${id})"/><path d="${heart}" fill="none" stroke="${isFav?'#e05c5c':'#bbb'}" stroke-width="0.5"/></svg>${pctHTML}</button>`;
}

function runMatcher(){
  const mType=document.getElementById('m-type').value;
  const mBien=document.getElementById('m-bien').value;
  const mBudget=parseFloat(document.getElementById('m-budget').value)||0;
  const mSurface=parseFloat(document.getElementById('m-surface').value)||0;
  const mPieces=parseInt(document.getElementById('m-pieces').value)||0;
  const mVille=document.getElementById('m-ville').value;
  if(!mType&&!mBien&&!mBudget&&!mSurface&&!mPieces&&!mVille){alert('Renseignez au moins un critère.');return;}
  matchScores={};
  properties.forEach(p=>{
    let s=0,t=0;
    if(mType){t+=30;if(p.type===mType)s+=30;}
    if(mBien){t+=20;if(p.bien===mBien)s+=20;}
    if(mBudget>0){t+=25;if(p.price<=mBudget)s+=25;else if(p.price<=mBudget*1.15)s+=15;else if(p.price<=mBudget*1.3)s+=8;}
    if(mSurface>0){t+=15;if(p.surface>=mSurface)s+=15;else if(p.surface>=mSurface*.85)s+=8;}
    if(mPieces>0&&p.pieces!==null){t+=10;if(p.pieces>=mPieces)s+=10;}
    if(mVille){t+=10;if(p.quartier===mVille)s+=10;}
    matchScores[p.id]=t>0?Math.round((s/t)*100):0;
  });
  renderGrid();
  if(currentTab!=='grid')document.querySelectorAll('.tab-btn')[0].click();
  document.getElementById('gridSection').scrollIntoView({behavior:'smooth',block:'start'});
  document.getElementById('countBar').innerHTML=`<strong>Compatibilité calculée !</strong> — Le cercle de chaque bien affiche votre % de correspondance`;
}

    </div>

    <div class="cf-row">
      <div class="cf-group"><label>Prénom <span class="cf-required">*</span></label><input id="cf-prenom" type="text" placeholder="Votre prénom" autocomplete="given-name"></div>
      <div class="cf-group"><label>Nom <span class="cf-required">*</span></label><input id="cf-nom" type="text" placeholder="Votre nom" autocomplete="family-name"></div>
    </div>
    <div class="cf-group"><label>E-mail <span class="cf-required">*</span></label><input id="cf-email" type="email" placeholder="votre@email.fr" autocomplete="email" oninput="updatePreview()"></div>
    <div class="cf-group"><label>Téléphone</label><input id="cf-tel" type="tel" placeholder="06 00 00 00 00" autocomplete="tel" oninput="updatePreview()"></div>

    <div id="msg-personnalise-wrap" style="display:${contactMsgType==='personnalise'?'block':'none'}">
      <div class="cf-group"><label>Votre message <span class="cf-required">*</span></label><textarea id="cf-msg" rows="4" placeholder="Décrivez votre demande, vos disponibilités pour une visite..." oninput="updatePreview()"></textarea></div>
    </div>

    <div style="font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--gris);margin-bottom:8px;margin-top:4px">Aperçu de l'e-mail qui sera envoyé</div>
    <div class="msg-preview" id="msgPreview"></div>

    <div class="rgpd-box">
      <div class="rgpd-title">🛡️ Protection de vos données (RGPD)</div>
      <p>Les informations que vous saisissez (nom, prénom, e-mail, téléphone) sont collectées <strong>uniquement</strong> dans le but de vous recontacter concernant votre demande immobilière.</p>
      <p>Elles sont transmises directement à <strong>GB Immobilier</strong> (responsable de traitement, SIREN&nbsp;792990855) et ne sont pas stockées sur ce site ni partagées avec des tiers.</p>
      <p>Conformément au <strong>RGPD (art.&nbsp;15–17)</strong>, vous pouvez exercer vos droits d'accès, rectification et suppression en écrivant à <a href="mailto:contact@gbi52.fr">contact@gbi52.fr</a>.</p>
    </div>

    <div class="rgpd-check">
      <input type="checkbox" id="cf-rgpd" onchange="updateSendBtn()">
      <label for="cf-rgpd">J'accepte que mes données personnelles soient transmises à GB Immobilier pour traiter ma demande. Je comprends que je peux exercer mes droits à tout moment en écrivant à <a href="mailto:contact@gbi52.fr">contact@gbi52.fr</a>. <span class="cf-required">*</span></label>
    </div>

    <div class="contact-send-row">
      <button class="btn-send" id="btnSend" onclick="sendContactMail()" disabled>
        <span>📨</span> Envoyer ma demande
      </button>
      <button class="btn-send-cancel" onclick="closeContact()">Annuler</button>
    </div>
    <div style="font-size:.7rem;color:#bbb;text-align:center;margin-top:10px">
      Aucun cookie, aucun tracking. Votre message part directement dans votre client mail.
    </div>`;

  // Init oninput listeners après render
  ['cf-prenom','cf-nom','cf-email','cf-tel','cf-msg'].forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.addEventListener('input',updatePreview);
  });
  updatePreview();
}

function setContactType(type) {
  contactMsgType = type;
  renderContactForm();
}

function buildMessage() {
  const prop = contactPropId ? properties.find(p=>p.id===contactPropId) : null;
  const prenom = (document.getElementById('cf-prenom')?.value||'').trim();
  const nom = (document.getElementById('cf-nom')?.value||'').trim();
  const email = (document.getElementById('cf-email')?.value||'').trim();
  const tel = (document.getElementById('cf-tel')?.value||'').trim();
  const msgPerso = (document.getElementById('cf-msg')?.value||'').trim();

  const propLine = prop
    ? `Bien concerné : ${prop.title} (Réf. ${prop.ref}) — ${fmtPrice(prop.price, prop.unit)}\n`
    : '';

  let contenu = '';
  if(contactMsgType === 'rapide') {
    contenu = `Bonjour,\n\nJe suis intéressé(e) par le bien suivant et souhaite obtenir plus d'informations ou convenir d'une visite.\n\n${propLine}`;
  } else {
    contenu = `Bonjour,\n\n${propLine}${msgPerso ? msgPerso+'\n' : ''}`;
  }

  const coordonnees = `\nMes coordonnées :\n  Nom : ${prenom} ${nom}${email?'\n  E-mail : '+email:''}${tel?'\n  Téléphone : '+tel:''}\n`;
  const fin = `\nCordialement,\n${prenom} ${nom}`;
  const rgpd = `\n\n---\nConsentement RGPD : En envoyant ce message, j'accepte que mes données personnelles (nom, e-mail, téléphone) soient utilisées par GB Immobilier dans le seul but de traiter ma demande immobilière, conformément au RGPD.`;

  return contenu + coordonnees + fin + rgpd;
}

function updatePreview() {
  const el = document.getElementById('msgPreview');
  if(!el) return;
  const msg = buildMessage();
  el.textContent = msg;
  updateSendBtn();
}

function updateSendBtn() {
  const btn = document.getElementById('btnSend');
  if(!btn) return;
  const prenom = (document.getElementById('cf-prenom')?.value||'').trim();
  const nom = (document.getElementById('cf-nom')?.value||'').trim();
  const email = (document.getElementById('cf-email')?.value||'').trim();
  const rgpd = document.getElementById('cf-rgpd')?.checked;
  const msgOk = contactMsgType === 'rapide' || (document.getElementById('cf-msg')?.value||'').trim().length > 2;
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  btn.disabled = !(prenom && nom && emailOk && rgpd && msgOk);
}

function sendContactMail() {
  const prop = contactPropId ? properties.find(p=>p.id===contactPropId) : null;
  const prenom = (document.getElementById('cf-prenom')?.value||'').trim();
  const nom = (document.getElementById('cf-nom')?.value||'').trim();
  const email = (document.getElementById('cf-email')?.value||'').trim();

  const subject = prop
    ? `Demande d'information — ${prop.title} (Réf. ${prop.ref})`
    : `Demande d'information — GB Immobilier`;

  const body = buildMessage();

  // Ouvre le client mail natif
  const mailto = `mailto:contact@gbi52.fr?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}&from=${encodeURIComponent(email)}`;
  window.location.href = mailto;

  // Afficher l'écran de succès
  setTimeout(()=>{
    const bodyEl = document.getElementById('contactModalBody');
    bodyEl.innerHTML = `
      <div class="contact-success">
        <div class="success-icon">✅</div>
        <h4>Votre message est prêt !</h4>
        <p>Votre client mail s'est ouvert avec le message pré-rempli.<br>
        Vérifiez-le et cliquez sur <strong>Envoyer</strong> dans votre application mail.<br><br>
        À défaut, écrivez-nous directement à <a href="mailto:contact@gbi52.fr" style="color:var(--or)">contact@gbi52.fr</a><br>
        ou appelez le <a href="tel:0325094652" style="color:var(--or)">03.25.09.46.52</a>.</p>
        <button class="btn-close-success" onclick="closeContact()">Fermer</button>
      </div>`;
  }, 600);
}

loadData();
renderGrid();
</script>
</body>
</html>

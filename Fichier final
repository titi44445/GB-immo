function toggleUrlPhotoInput(){const wrap=document.getElementById('urlPhotoInputWrap');wrap.style.display=wrap.style.display==='none'?'block':'none';}
function addUrlPhoto(){const input=document.getElementById('urlPhotoInput');const url=input.value.trim();if(!url)return;if(formPhotos.length>=10){showToast('⚠️ Maximum 10 photos par bien');return;}formPhotos.push(url);input.value='';renderPhotoPreview();showToast('🖼️ Photo URL ajoutée');}
function handlePhotoUpload(event){handleDroppedFiles(event.target.files);event.target.value='';}
function handleDroppedFiles(fileList){
  const files=Array.from(fileList).filter(f=>f.type.startsWith('image/'));
  const remaining=10-formPhotos.length;
  if(!files.length)return;
  if(remaining<=0){showToast('⚠️ Maximum 10 photos par bien');return;}
  const toProcess=files.slice(0,remaining);
  let processed=0;
  toProcess.forEach(file=>{
    if(file.size>5*1024*1024){showToast(`⚠️ ${file.name} dépasse 5 Mo, ignorée`);processed++;if(processed===toProcess.length)renderPhotoPreview();return;}
    const reader=new FileReader();
    reader.onload=e=>{resizeImage(e.target.result,1200,900,0.82).then(resized=>{formPhotos.push(resized);processed++;if(processed===toProcess.length)renderPhotoPreview();});};
    reader.readAsDataURL(file);
  });
}
function resizeImage(dataUrl,maxW,maxH,quality){
  return new Promise(resolve=>{
    const img=new Image();
    img.onload=()=>{
      let w=img.width,h=img.height;
      if(w>maxW||h>maxH){const ratio=Math.min(maxW/w,maxH/h);w=Math.round(w*ratio);h=Math.round(h*ratio);}
      const canvas=document.createElement('canvas');canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      resolve(canvas.toDataURL('image/jpeg',quality));
    };
    img.src=dataUrl;
  });
}

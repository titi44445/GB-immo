<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GB Immobilier — Saint-Dizier</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--noir:#0d0d0d;--blanc:#f8f5f0;--or:#c8a96e;--or-clair:#e8d5a8;--gris:#6b6b6b;--gris-clair:#ebebeb;--rouge:#e05c5c;--vert:#5cad7b;--fond:#faf8f5}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--fond);color:var(--noir);overflow-x:hidden}
header{background:var(--noir);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:72px;position:sticky;top:0;z-index:1000;box-shadow:0 2px 20px rgba(0,0,0,.4)}
.logo{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:900;color:var(--blanc);letter-spacing:-.5px}
.logo span{color:var(--or)}
.header-contact{color:var(--or-clair);font-size:.85rem;text-align:right;line-height:1.4}
.header-contact strong{color:var(--or);display:block;font-size:1rem}
.hero{background:linear-gradient(135deg,#0d0d0d 0%,#1a1a2e 50%,#16213e 100%);padding:80px 40px 60px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23c8a96e' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");opacity:.5}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:900;color:var(--blanc);position:relative;margin-bottom:12px}
.hero h1 em{color:var(--or);font-style:normal}
.hero p{color:#aaa;font-size:1.05rem;position:relative;margin-bottom:40px}
.matcher-box{background:rgba(255,255,255,.04);border:1px solid rgba(200,169,110,.3);border-radius:16px;padding:28px 32px;max-width:860px;margin:0 auto;position:relative;backdrop-filter:blur(10px)}
.matcher-title{font-family:'Playfair Display',serif;color:var(--or);font-size:1.1rem;margin-bottom:20px;text-align:left}
.matcher-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px}
.matcher-field label{display:block;color:#888;font-size:.75rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.matcher-field select,.matcher-field input{width:100%;background:rgba(255,255,255,.08);border:1px solid rgba(200,169,110,.25);border-radius:8px;padding:10px 14px;color:var(--blanc);font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;transition:border .2s}
.matcher-field select:focus,.matcher-field input:focus{border-color:var(--or)}
.matcher-field select option{background:#1a1a2e}
.btn-match{margin-top:20px;width:100%;background:var(--or);color:var(--noir);border:none;border-radius:10px;padding:14px;font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;transition:background .2s,transform .1s}
.btn-match:hover{background:var(--or-clair);transform:translateY(-1px)}
.tabs-section{padding:40px 40px 0;max-width:1400px;margin:0 auto}
.tabs{display:flex;gap:8px;border-bottom:2px solid var(--gris-clair);margin-bottom:32px}
.tab-btn{padding:12px 24px;background:none;border:none;font-family:'DM Sans',sans-serif;font-size:.95rem;font-weight:500;color:var(--gris);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s;border-radius:6px 6px 0 0}
.tab-btn:hover{color:var(--noir);background:rgba(200,169,110,.1)}
.tab-btn.active{color:var(--or);border-bottom-color:var(--or);background:rgba(200,169,110,.08);font-weight:700}
.tab-count{background:var(--or);color:var(--noir);font-size:.7rem;font-weight:700;border-radius:20px;padding:2px 7px;margin-left:6px}
.quick-filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;padding:0 40px;max-width:1400px;margin-left:auto;margin-right:auto}
.qf-btn{padding:7px 16px;border:1.5px solid var(--gris-clair);border-radius:20px;background:#fff;font-size:.82rem;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;color:#444}
.qf-btn:hover,.qf-btn.active{border-color:var(--or);color:var(--or);background:rgba(200,169,110,.08)}
.count-bar{padding:0 40px 16px;max-width:1400px;margin:0 auto;color:var(--gris);font-size:.88rem}
.count-bar strong{color:var(--noir)}
.properties-section{padding:0 40px 60px;max-width:1400px;margin:0 auto}
.properties-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px}
.property-card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.07);transition:transform .25s,box-shadow .25s;position:relative;display:flex;flex-direction:column;cursor:pointer}
.property-card:hover{transform:translateY(-4px);box-shadow:0 12px 30px rgba(0,0,0,.13)}
.property-card.hidden{display:none}
.card-img-wrap{position:relative;width:100%;height:200px;overflow:hidden;background:linear-gradient(135deg,#e8e0d0,#c8bca8)}
.card-img{width:100%;height:200px;object-fit:cover;display:block}
.card-img-placeholder{width:100%;height:200px;background:linear-gradient(135deg,#e8e0d0,#c8bca8);display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:3rem;gap:8px}
.card-img-placeholder small{font-size:.72rem;color:#999;font-family:'DM Sans',sans-serif}
.gallery-dots{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);display:flex;gap:5px;z-index:2}
.gallery-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.6);cursor:pointer;transition:background .2s,transform .2s;border:none;padding:0}
.gallery-dot.active{background:#fff;transform:scale(1.3)}
.gallery-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.4);color:#fff;border:none;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;z-index:3;opacity:0;transition:opacity .2s;backdrop-filter:blur(4px)}
.card-img-wrap:hover .gallery-nav{opacity:1}
.gallery-nav.prev{left:8px}
.gallery-nav.next{right:52px}
.photo-count-badge{position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,.55);color:#fff;font-size:.65rem;font-weight:700;padding:3px 7px;border-radius:10px;backdrop-filter:blur(4px);z-index:2}
.card-badge{position:absolute;top:14px;left:14px;padding:5px 12px;border-radius:20px;font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;backdrop-filter:blur(4px)}
.badge-location{background:rgba(61,122,191,.9);color:#fff}
.badge-vente{background:rgba(200,169,110,.9);color:#0d0d0d}
.badge-commerce{background:rgba(92,173,123,.9);color:#fff}
.badge-baisse{position:absolute;top:14px;right:58px;background:rgba(224,92,92,.9);color:#fff;padding:4px 10px;border-radius:20px;font-size:.7rem;font-weight:700;backdrop-filter:blur(4px)}
.fav-ring-btn{position:absolute;top:10px;right:10px;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.92);backdrop-filter:blur(6px);border:2.5px solid #ddd;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .18s,border-color .18s,box-shadow .18s;box-shadow:0 2px 8px rgba(0,0,0,.15);overflow:visible;padding:0;flex-direction:column;gap:0}
.fav-ring-btn:hover{transform:scale(1.12);box-shadow:0 4px 14px rgba(0,0,0,.22)}
.fav-ring-btn.liked{border-color:var(--rouge)}
.fav-ring-btn svg.heart-svg{width:20px;height:20px;display:block}
.fav-ring-btn .pct-txt{font-size:.44rem;font-weight:800;line-height:1;margin-top:1px;pointer-events:none}
.fav-ring-btn svg.ring-svg{position:absolute;inset:-3px;width:calc(100% + 6px);height:calc(100% + 6px);border-radius:50%;pointer-events:none;overflow:visible}
.ring-track{fill:none;stroke:#eee;stroke-width:3}
.ring-fill{fill:none;stroke-width:3;stroke-linecap:round;transition:stroke-dashoffset .6s ease}
.card-body{padding:16px;flex:1;display:flex;flex-direction:column;gap:8px}
.card-title{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--noir);line-height:1.3}
.card-location{font-size:.82rem;color:var(--gris)}
.card-specs{display:flex;gap:8px;flex-wrap:wrap}
.spec-tag{background:var(--fond);border:1px solid var(--gris-clair);padding:4px 10px;border-radius:6px;font-size:.78rem;color:#555}
.card-price{font-size:1.35rem;font-weight:700;color:var(--noir);margin-top:auto}
.card-price span{font-size:.8rem;font-weight:400;color:var(--gris)}
.card-footer{padding:12px 16px;border-top:1px solid var(--gris-clair);display:flex;align-items:center;justify-content:space-between}
.ref-label{font-size:.72rem;color:#999}
.btn-voir{padding:8px 18px;background:var(--noir);color:var(--blanc);border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;text-decoration:none;transition:background .2s;display:inline-block}
.btn-voir:hover{background:var(--or);color:var(--noir)}
.map-section{padding:0 40px 60px;max-width:1400px;margin:0 auto;display:none}
.map-section.active{display:block}
.map-wrapper{width:100%;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.12)}
.map-wrapper iframe{width:100%;height:560px;border:none;display:block}
.map-legend{display:flex;gap:16px;flex-wrap:wrap;margin-top:16px;padding:14px 20px;background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.06);align-items:center}
.map-legend span{font-size:.83rem;display:flex;align-items:center;gap:6px}
.dot{width:12px;height:12px;border-radius:50%;display:inline-block}
.dot-loc{background:#3d7abf}.dot-vte{background:#c8a96e}.dot-com{background:#5cad7b}
.map-info{color:var(--gris);font-size:.82rem;margin-left:auto}
.fav-section{padding:0 40px 60px;max-width:1400px;margin:0 auto;display:none}
.fav-section.active{display:block}
.empty-fav{text-align:center;padding:80px 20px;color:var(--gris)}
.empty-fav .big-heart{font-size:4rem;margin-bottom:16px}
.admin-trigger{position:fixed;bottom:24px;right:24px;width:42px;height:42px;border-radius:50%;background:rgba(13,13,13,.7);border:1.5px solid rgba(200,169,110,.4);color:var(--or);font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:900;transition:all .2s;backdrop-filter:blur(6px)}
.admin-trigger:hover{background:var(--noir);border-color:var(--or);transform:scale(1.1)}
.admin-login-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:3000;display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px)}
.admin-login-overlay.open{display:flex}
.admin-login-box{background:#fff;border-radius:20px;padding:40px;width:360px;text-align:center;animation:fadeIn .25s}
.admin-login-box h2{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:8px}
.admin-login-box p{color:var(--gris);font-size:.88rem;margin-bottom:24px}
.admin-login-box input{width:100%;padding:12px 16px;border:1.5px solid var(--gris-clair);border-radius:10px;font-size:1rem;font-family:'DM Sans',sans-serif;outline:none;margin-bottom:12px;transition:border .2s}
.admin-login-box input:focus{border-color:var(--or)}
.admin-login-box .err{color:var(--rouge);font-size:.82rem;margin-bottom:10px;min-height:18px}
.admin-login-box .btn-login{width:100%;padding:13px;background:var(--noir);color:#fff;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s}
.admin-login-box .btn-login:hover{background:var(--or);color:var(--noir)}
.admin-login-box .btn-cancel{margin-top:10px;background:none;border:none;color:var(--gris);font-size:.85rem;cursor:pointer;font-family:'DM Sans',sans-serif}
.admin-panel{position:fixed;top:0;right:-440px;width:440px;height:100vh;background:#fff;z-index:2500;box-shadow:-4px 0 30px rgba(0,0,0,.18);transition:right .3s ease;display:flex;flex-direction:column;overflow:hidden}
.admin-panel.open{right:0}
.admin-panel-header{background:var(--noir);padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.admin-panel-header h3{font-family:'Playfair Display',serif;color:var(--or);font-size:1.2rem}
.admin-close{background:none;border:none;color:#888;font-size:1.4rem;cursor:pointer}
.admin-close:hover{color:#fff}
.admin-tabs{display:flex;border-bottom:1px solid var(--gris-clair);flex-shrink:0}
.admin-tab{flex:1;padding:12px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:.85rem;cursor:pointer;color:var(--gris);font-weight:500;transition:all .2s;border-bottom:2px solid transparent}
.admin-tab.active{color:var(--or);border-bottom-color:var(--or);font-weight:700}
.admin-content{flex:1;overflow-y:auto;padding:20px}
.admin-bien-item{border:1px solid var(--gris-clair);border-radius:10px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:border-color .2s}
.admin-bien-item:hover{border-color:var(--or)}
.admin-bien-thumb{width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0;background:linear-gradient(135deg,#e8e0d0,#c8bca8);display:flex;align-items:center;justify-content:center;font-size:1.2rem;overflow:hidden}
.admin-bien-thumb img{width:100%;height:100%;object-fit:cover;border-radius:8px}
.admin-bien-info{flex:1;min-width:0}
.admin-bien-title{font-weight:700;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.admin-bien-meta{font-size:.74rem;color:var(--gris);display:flex;gap:8px;margin-top:2px;align-items:center;flex-wrap:wrap}
.admin-bien-ref{background:#f0f0f0;border-radius:4px;padding:1px 6px;font-size:.7rem;font-weight:700}
.photo-badge{background:rgba(200,169,110,.15);color:var(--or);border-radius:4px;padding:1px 6px;font-size:.68rem;font-weight:700;border:1px solid rgba(200,169,110,.3)}
.admin-bien-actions{display:flex;gap:6px;flex-shrink:0}
.btn-icon{width:32px;height:32px;border-radius:8px;border:1.5px solid var(--gris-clair);background:none;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;transition:all .2s}
.btn-icon:hover{border-color:var(--or);background:rgba(200,169,110,.1)}
.btn-icon.del:hover{border-color:var(--rouge);background:rgba(224,92,92,.1)}
.btn-icon.baisse-on{border-color:var(--rouge);background:rgba(224,92,92,.08);color:var(--rouge)}
.form-group{margin-bottom:14px}
.form-group label{display:block;font-size:.75rem;text-transform:uppercase;letter-spacing:.8px;color:var(--gris);margin-bottom:5px;font-weight:600}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 12px;border:1.5px solid var(--gris-clair);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;transition:border .2s;background:#fff}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--or)}
.form-group textarea{resize:vertical;min-height:80px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.form-check{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.form-check input[type=checkbox]{width:18px;height:18px;cursor:pointer;accent-color:var(--or)}
.form-check label{font-size:.9rem;cursor:pointer}
.btn-save{width:100%;padding:13px;background:var(--vert,#5cad7b);color:#fff;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:8px;transition:background .2s}
.btn-save:hover{background:#4a9a6a}
.btn-cancel-form{width:100%;padding:11px;background:none;border:1.5px solid var(--gris-clair);border-radius:10px;font-size:.9rem;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:6px;transition:border-color .2s}
.btn-cancel-form:hover{border-color:var(--or)}
.admin-section-title{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center}
.btn-add-new{padding:8px 16px;background:var(--noir);color:var(--blanc);border:none;border-radius:8px;font-size:.8rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s}
.btn-add-new:hover{background:var(--or);color:var(--noir)}
.admin-search{width:100%;padding:9px 12px;border:1.5px solid var(--gris-clair);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;margin-bottom:14px}
.admin-search:focus{border-color:var(--or)}
.admin-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
.stat-box{background:var(--fond);border-radius:10px;padding:14px;text-align:center}
.stat-box .stat-n{font-size:1.6rem;font-weight:900;font-family:'Playfair Display',serif;color:var(--or)}
.stat-box .stat-l{font-size:.72rem;color:var(--gris);text-transform:uppercase;letter-spacing:.5px}
.toast{position:fixed;bottom:80px;right:24px;background:var(--noir);color:var(--or);padding:12px 20px;border-radius:10px;font-size:.88rem;font-weight:600;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none}
.toast.show{opacity:1}
.photo-upload-section{background:var(--fond);border-radius:12px;padding:16px;margin-bottom:14px;border:1.5px solid var(--gris-clair)}
.photo-upload-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.photo-upload-header span{font-size:.75rem;text-transform:uppercase;letter-spacing:.8px;color:var(--gris);font-weight:600}
.photo-upload-header small{font-size:.7rem;color:#aaa}
.photo-drop-zone{border:2px dashed var(--gris-clair);border-radius:10px;padding:24px 16px;text-align:center;cursor:pointer;transition:all .25s;background:#fff;position:relative}
.photo-drop-zone:hover,.photo-drop-zone.dragover{border-color:var(--or);background:rgba(200,169,110,.04)}
.photo-drop-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.photo-drop-icon{font-size:2rem;margin-bottom:8px}
.photo-drop-text{font-size:.85rem;color:var(--gris);font-weight:500}
.photo-drop-sub{font-size:.72rem;color:#bbb;margin-top:4px}
.photo-preview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
.photo-preview-item{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:4/3;background:#eee;cursor:grab}
.photo-preview-item img{width:100%;height:100%;object-fit:cover;display:block}
.photo-preview-item .remove-photo{position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(224,92,92,.9);color:#fff;border:none;cursor:pointer;font-size:.75rem;display:flex;align-items:center;justify-content:center;font-weight:700;line-height:1;transition:transform .15s}
.photo-preview-item .remove-photo:hover{transform:scale(1.15)}
.photo-preview-item .main-badge{position:absolute;bottom:4px;left:4px;background:rgba(200,169,110,.9);color:#0d0d0d;font-size:.6rem;font-weight:800;padding:2px 6px;border-radius:4px;text-transform:uppercase;letter-spacing:.5px}
.photo-preview-item .set-main-btn{position:absolute;bottom:4px;right:4px;background:rgba(0,0,0,.55);color:#fff;font-size:.6rem;padding:2px 6px;border-radius:4px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:600;opacity:0;transition:opacity .2s}
.photo-preview-item:hover .set-main-btn{opacity:1}
.photo-preview-item.is-main{outline:2.5px solid var(--or);outline-offset:-2px}
.photo-counter{font-size:.75rem;color:var(--gris);margin-top:8px;text-align:center}
.url-photo-toggle{font-size:.78rem;color:var(--or);cursor:pointer;text-decoration:underline;margin-top:6px;display:inline-block;background:none;border:none;font-family:'DM Sans',sans-serif}
.gallery-modal{position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:4000;display:none;align-items:center;justify-content:center;flex-direction:column}
.gallery-modal.open{display:flex}
.gallery-modal-img{max-width:90vw;max-height:80vh;object-fit:contain;border-radius:8px;user-select:none}
.gallery-modal-nav{display:flex;align-items:center;gap:24px;margin-top:20px}
.gallery-modal-btn{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);color:#fff;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.gallery-modal-btn:hover{background:rgba(200,169,110,.3);border-color:var(--or)}
.gallery-modal-counter{color:#888;font-size:.9rem;min-width:60px;text-align:center}
.gallery-modal-close{position:absolute;top:20px;right:24px;background:none;border:none;color:#888;font-size:1.8rem;cursor:pointer;transition:color .2s}
